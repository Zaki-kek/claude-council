# claude-council - provider API keys
# Copy to a private location or export in your shell. NEVER commit real keys.
# At least one provider (or a codex / gemini CLI) is required.

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI (GPT / Codex)
OPENAI_API_KEY=your-openai-api-key-here

# xAI Grok (XAI_API_KEY is canonical; GROK_API_KEY is the legacy alias)
XAI_API_KEY=your-xai-api-key-here

# Perplexity
PERPLEXITY_API_KEY=your-perplexity-api-key-here

# Optional model overrides
# GEMINI_MODEL=
# OPENAI_MODEL=
# GROK_MODEL=
# PERPLEXITY_MODEL=
# COUNCIL_MAX_TOKENS=2048
